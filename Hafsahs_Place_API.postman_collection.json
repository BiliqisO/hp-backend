          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/coupons/{{couponId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["api","admin","coupons","{{couponId}}","deactivate"] }
          }
        }
      ]
    },

    {
      "name": "📋 Orders",
      "item": [
        {
          "name": "Place Order (no coupon)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
