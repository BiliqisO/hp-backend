    {
      "name": "🏷 Coupons",
      "item": [
        {
          "name": "Validate Coupon (Preview Discount)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/coupons/validate?code=SAVE20&orderTotal=50000", "host": ["{{baseUrl}}"], "path": ["api","coupons","validate"], "query": [{ "key": "code", "value": "SAVE20" }, { "key": "orderTotal", "value": "50000" }] }
          }
        },
        {
          "name": "Create Coupon (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('couponId', pm.response.json().id);",
            "}"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"SAVE20\",\n  \"type\": \"PERCENTAGE\",\n  \"value\": 20,\n  \"minOrderAmount\": 10000,\n  \"maxUses\": 100,\n  \"expiresAt\": \"2027-12-31T23:59:59\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/admin/coupons", "host": ["{{baseUrl}}"], "path": ["api","admin","coupons"] }
          }
        },
