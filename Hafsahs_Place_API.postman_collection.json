            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"OFF5000\",\n  \"type\": \"FIXED_AMOUNT\",\n  \"value\": 5000,\n  \"minOrderAmount\": 25000\n}" },
            "url": { "raw": "{{baseUrl}}/api/admin/coupons", "host": ["{{baseUrl}}"], "path": ["api","admin","coupons"] }
          }
        },
        {
