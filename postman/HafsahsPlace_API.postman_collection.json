      "name": "9. Custom Orders",
      "item": [
        {
          "name": "Create Custom Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('customOrderId', res.id);",
                  "  pm.collectionVariables.set('customOrderNumber', res.orderNumber);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has order number', () => {",
                  "  pm.expect(pm.response.json().orderNumber).to.match(/^HPC-/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/custom-orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"designDescription\": \"I want a floor-length aso-ebi dress in teal green with gold embroidery. Off-shoulder neckline with bell sleeves.\",\n  \"measurementId\": {{measurementId}},\n  \"preferredFabric\": \"George fabric\",\n  \"preferredColor\": \"Teal Green\",\n  \"budgetRange\": \"150000-250000\",\n  \"eventDate\": \"2026-07-15\",\n  \"notes\": \"The event is a wedding reception, I want to stand out!\"\n}"
            }
          }
        },
        {
          "name": "Get My Custom Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/custom-orders"
          }
        },
        {
          "name": "Get Custom Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/custom-orders/{{customOrderId}}"
          }
        },
        {
          "name": "Track Custom Order (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/custom-orders/track/{{customOrderNumber}}"
          }
        },
        {
          "name": "[Admin] Get All Custom Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/custom-orders/admin/all"
          }
        },
        {
          "name": "[Admin] Set Price Quote",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Price set', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.estimatedPrice).to.eql(200000.00);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/custom-orders/admin/{{customOrderId}}/price?estimatedPrice=200000.00",
              "host": ["{{baseUrl}}"],
              "path": ["api", "custom-orders", "admin", "{{customOrderId}}", "price"],
              "query": [{ "key": "estimatedPrice", "value": "200000.00" }]
            }
          }
        },
        {
          "name": "[Admin] Update Custom Order Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status updated', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('QUOTE_SENT');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/custom-orders/admin/{{customOrderId}}/status?status=QUOTE_SENT",
              "host": ["{{baseUrl}}"],
              "path": ["api", "custom-orders", "admin", "{{customOrderId}}", "status"],
              "query": [{ "key": "status", "value": "QUOTE_SENT" }]
            }
          }
        },
        {
          "name": "Cancel Custom Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Cancelled', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/custom-orders/{{customOrderId}}/cancel"
          }
        }
      ]
    }
  ]
}
