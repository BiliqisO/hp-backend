{
  "info": {
    "name": "Hafsah's Place API",
    "description": "End-to-end API testing for Hafsah's Place e-commerce backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "orderNumber", "value": "" },
    { "key": "customOrderId", "value": "" },
    { "key": "customOrderNumber", "value": "" },
    { "key": "paymentReference", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "measurementId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.token);",
                  "pm.collectionVariables.set('userId', res.id);",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has token', () => pm.expect(res.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Aisha\",\n  \"lastName\": \"Bello\",\n  \"email\": \"aisha@test.com\",\n  \"password\": \"password123\",\n  \"phoneNumber\": \"08012345678\",\n  \"address\": \"12 Marina Street\",\n  \"city\": \"Lagos\",\n  \"state\": \"Lagos\",\n  \"country\": \"Nigeria\"\n}"
            }
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.token);",
                  "pm.collectionVariables.set('userId', res.id);",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(res.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aisha@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register Admin (requires admin token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', res.token);",
                  "}",
                  "pm.test('Status is 201 or 403', () => [201, 403].includes(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/register/admin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@hafsahsplace.com\",\n  \"password\": \"admin123456\",\n  \"phoneNumber\": \"08099999999\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', res.token);",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hafsahsplace.com\",\n  \"password\": \"admin123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. User Profile",
      "item": [
        {
          "name": "Get My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has email', () => pm.expect(res.email).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Phone updated', () => pm.expect(res.phoneNumber).to.eql('08098765432'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"08098765432\",\n  \"address\": \"25 Admiralty Way, Lekki\",\n  \"city\": \"Lagos\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Categories",
      "item": [
        {
          "name": "Get All Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "if (Array.isArray(res) && res.length > 0) {",
                  "  pm.collectionVariables.set('categoryId', res[0].id);",
                  "} else if (res.content && res.content.length > 0) {",
                  "  pm.collectionVariables.set('categoryId', res.content[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        }
      ]
    },
    {
      "name": "4. Products",
      "item": [
        {
          "name": "Create Product (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('productId', res.id);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aurora Evening Gown\",\n  \"description\": \"Stunning silk satin evening gown with hand-sewn lace details\",\n  \"basePrice\": 185000.00,\n  \"categoryId\": {{categoryId}},\n  \"isCustomizable\": true,\n  \"isFeatured\": true,\n  \"isAvailable\": true,\n  \"slug\": \"aurora-evening-gown\",\n  \"sku\": \"HP-EVE-001\",\n  \"fabricType\": \"Silk Satin\",\n  \"careInstructions\": \"Dry clean only\"\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "if (res.content && res.content.length > 0) {",
                  "  pm.collectionVariables.set('productId', res.content[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=12",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "12" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/slug/aurora-evening-gown"
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/featured"
          }
        },
        {
          "name": "Get Latest Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/latest"
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/search?keyword=aurora",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "search"],
              "query": [{ "key": "keyword", "value": "aurora" }]
            }
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/category/{{categoryId}}"
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basePrice\": 195000.00,\n  \"isFeatured\": true\n}"
            }
          }
        }
      ]
    },
