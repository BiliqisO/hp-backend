          "name": "Cancel Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CANCELLED', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
