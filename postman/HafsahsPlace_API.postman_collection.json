                  "pm.test('Correct order', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.orderNumber).to.eql(pm.collectionVariables.get('orderNumber'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/track/{{orderNumber}}"
          }
