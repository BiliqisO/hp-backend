                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('orderId', res.id);",
                  "  pm.collectionVariables.set('orderNumber', res.orderNumber);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has order number', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.orderNumber).to.match(/^HP-\\d{8}-[A-Z0-9]{6}$/);",
                  "});"
