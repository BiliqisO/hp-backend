            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"quantity\": 1,\n      \"specialInstructions\": \"Please add extra lace trim\"\n    }\n  ],\n  \"shippingAddress\": \"25 Admiralty Way, Lekki Phase 1\",\n  \"shippingCity\": \"Lagos\",\n  \"shippingState\": \"Lagos\",\n  \"shippingPhone\": \"08012345678\",\n  \"notes\": \"Please call before delivery\"\n}"
